{
  "name": "",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test --experimental-strip-types app/lib/*.test.ts",
    "ext:test": "rm -rf .tmp/ext-test && mkdir -p .tmp/ext-test && tsc --module commonjs --target es2022 --lib es2022,dom --moduleResolution node --types node,chrome --esModuleInterop --skipLibCheck --outDir .tmp/ext-test chrome-extension/src/lib/api.test.ts chrome-extension/src/lib/billing.test.ts && printf '{\"type\":\"commonjs\"}\\n' > .tmp/ext-test/package.json && node --test .tmp/ext-test/lib/api.test.js .tmp/ext-test/lib/billing.test.js",
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "gen:api": "openapi-typescript ${API_BASE_URL:-http://127.0.0.1:8000}/openapi.json -o app/types/api.generated.ts",
    "ext:dev": "vite build --watch --config chrome-extension/vite.config.ts",
    "ext:build": "vite build --config chrome-extension/vite.config.ts && cd chrome-extension/dist && zip -r ../donkey-extension-prod.zip ."
  },
  "dependencies": {
    "@iconify-json/logos": "^1.2.10",
    "@iconify/react": "^6.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.36.0",
    "isbot": "^5.1.31",
    "lucide-react": "^0.542.0",
    "openapi-typescript": "^7.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/chrome": "^0.1.37",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
